{
  "name": "@thelogicatelier/docxa",
  "version": "0.1.1",
  "description": "AI-powered documentation intelligence system",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "docxa": "./dist/interfaces/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/interfaces/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "tests/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [
    "documentation",
    "ai",
    "llm",
    "typescript",
    "ax-llm"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/achatt89/docxa.git"
  },
  "bugs": {
    "url": "https://github.com/achatt89/docxa/issues"
  },
  "homepage": "https://achatt89.github.io/docxa/",
  "license": "MIT",
  "dependencies": {
    "@ax-llm/ax": "^19.0.15",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "uuid": "^13.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.4",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^1.0.4"
  }
}
